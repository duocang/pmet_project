{
  "_note": "Parameters the pre-computed PMET indexes were built with. Keys are species directory names under data/indexing/. Values are shown as read-only 'Fixed parameters' in the submit form. Edit freely; changes are picked up on the next page load (no restart needed). Defaults below assume the Zenodo 8435321 build pipeline — verify and override if you rebuild an index with different settings. Optional nested key 'by_motif_db' lets you override per motif database.",
  "_fields": {
    "promoter_length": "int (bp used when extracting promoter sequences)",
    "promoter_num": "int (size of the promoter universe used by FIMO)",
    "max_match": "int (top-k FIMO hits per gene baked into pair index)",
    "fimo_threshold": "float (FIMO p-value cutoff used when the index was built)",
    "ic_threshold": "int (IC filter applied by pair_parallel; runtime-configurable but normally left at the build-time value)",
    "utr5": "'Yes' | 'No' (whether 5' UTR was included in the promoter)",
    "promoters_overlap": "'NoOverlap' | 'AllowOverlap' (overlap handling)"
  },

